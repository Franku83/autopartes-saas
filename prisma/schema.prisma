// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  STAFF
  VIEWER
}

enum GlobalRole {
  SUPERADMIN
  USER
}

enum StockStatus {
  AVAILABLE
  RESERVED
  SOLD
  DISCARDED
}

model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  name               String?
  passwordHash       String
  globalRole         GlobalRole  @default(USER)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  lastOrganizationId String?

  memberships        Membership[]
  sales              Sale[]      @relation("SalesSoldBy")
}

model Organization {
  id               String           @id @default(cuid())
  name             String
  joinCodeHash     String?
  joinCodeExpiresAt DateTime?
  joinCodeMaxUses  Int?
  joinCodeUses     Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  memberships      Membership[]
  locations        Location[]
  vehicles         Vehicle[]
  partModels       PartModel[]
  stockItems       StockItem[]
  sales            Sale[]
  exchangeRates    ExchangeRate[]
  allowedEmails    OrgAllowedEmail[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(STAFF)
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Location {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  stockItems     StockItem[]

  @@index([organizationId])
}

model ExchangeRate {
  id             String       @id @default(cuid())
  organizationId String
  rateVesPerUsd  Decimal      @db.Decimal(18, 6)
  effectiveAt    DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, effectiveAt])
}

model Vehicle {
  id              String       @id @default(cuid())
  organizationId  String
  make            String
  model           String
  year            Int
  trim            String?
  engineCode      String?
  vin             String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdByUserId String?

  organization    Organization @relation(fields: [organizationId], references: [id])
  stockItems      StockItem[]

  @@index([organizationId])
  @@index([organizationId, make, model, year])
  @@index([organizationId, engineCode])
}

model PartModel {
  id              String       @id @default(cuid())
  organizationId  String
  sku             String
  name            String
  category        String
  compatibility   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdByUserId String?

  organization    Organization @relation(fields: [organizationId], references: [id])
  stockItems      StockItem[]

  @@unique([organizationId, sku])
  @@index([organizationId, name])
  @@index([organizationId, category])
}

model StockItem {
  id              String       @id @default(cuid())
  organizationId  String
  partModelId     String
  vehicleId       String?
  locationId      String?
  quantity        Int          @default(1)
  status          StockStatus  @default(AVAILABLE)
  priceUsd        Decimal      @db.Decimal(18, 2)
  priceVes        Decimal?     @db.Decimal(18, 2)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdByUserId String?

  organization    Organization @relation(fields: [organizationId], references: [id])
  partModel       PartModel    @relation(fields: [partModelId], references: [id])
  vehicle         Vehicle?     @relation(fields: [vehicleId], references: [id])
  location        Location?    @relation(fields: [locationId], references: [id])

  saleItems       SaleItem[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, vehicleId])
  @@index([organizationId, locationId])
  @@index([organizationId, partModelId])
}

model Sale {
  id             String       @id @default(cuid())
  organizationId String
  invoiceNumber  String?
  currency       String       @default("USD")
  totalUsd       Decimal?     @db.Decimal(18, 2)
  totalVes       Decimal?     @db.Decimal(18, 2)
  createdAt      DateTime     @default(now())
  soldByUserId   String

  organization   Organization @relation(fields: [organizationId], references: [id])
  soldBy         User         @relation("SalesSoldBy", fields: [soldByUserId], references: [id])
  items          SaleItem[]

  @@index([organizationId, createdAt])
  @@index([organizationId, invoiceNumber])
}

model SaleItem {
  id            String    @id @default(cuid())
  saleId        String
  stockItemId   String
  quantity      Int       @default(1)
  unitPriceUsd  Decimal?  @db.Decimal(18, 2)
  unitPriceVes  Decimal?  @db.Decimal(18, 2)

  sale          Sale      @relation(fields: [saleId], references: [id])
  stockItem     StockItem @relation(fields: [stockItemId], references: [id])

  @@index([saleId])
  @@index([stockItemId])
}

model OrgAllowedEmail {
  id              String       @id @default(cuid())
  organizationId  String
  email           String
  roleToAssign    Role         @default(STAFF)
  createdAt       DateTime     @default(now())
  createdByUserId String?

  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
}